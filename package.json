{
  "name": "octor-compressor",
  "version": "1.0.0",
  "description": "Octor Compressor - 免费开源的图片压缩神器支持 PNG/JPEG/WebP/AVIF/JPEG XL 格式，集成 Squoosh/Sharp/pngquant/mozjpeg/gifsicle/oxipng 多引擎",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "website": "npx serve website -p 3000",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.octor.compressor",
    "productName": "Octor Compressor",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "compression/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "icon": "assets/icon.png",
      "identity": null
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [
    "image",
    "compression",
    "png",
    "jpg",
    "gif",
    "webp",
    "avif",
    "jxl",
    "jpegxl",
    "squoosh",
    "sharp",
    "oxipng"
  ],
  "author": "Octor Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "serve": "^14.2.0"
  },
  "dependencies": {
    "@squoosh/lib": "^0.3.1",
    "sharp": "^0.35.2"
  },
  "productName": "Octor Compressor"
}
